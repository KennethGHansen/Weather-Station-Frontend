{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "weather-station", // <- put your worker name here
	"main": "worker.js", // <- we'll add this next
	"compatibility_date": "2026-04-14",
	"assets": {
		"directory": "./", // repo root where index.html + app.js live
		"binding": "ASSETS",
		"run_worker_first": false
	},
	"kv_namespaces": [
		{
			"id": "acd6a77f01684e34bd57863bf27f4284",
			"binding": "WEATHER_KV"
		}
	]
}